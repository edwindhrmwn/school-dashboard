# Salin file ini menjadi .env lalu isi nilainya. JANGAN commit .env.

# Google OAuth 2.0 Web Client ID — dari Google Cloud Console
# APIs & Services > Credentials > OAuth 2.0 Client IDs > Web application
# Tambahkan http://localhost:5173 ke Authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ID Google Spreadsheet (dari URL sheet)
VITE_SPREADSHEET_ID=your_spreadsheet_id

# Scope OAuth untuk baca/tulis Sheets
VITE_GOOGLE_SCOPE=https://www.googleapis.com/auth/spreadsheets
